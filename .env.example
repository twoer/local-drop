# 服务端配置（覆盖 design.md §13.1 默认值）
# PORT=3000
# LD_TRUST_PROXY=true
# LD_GRACE_PERIOD_MS=15000
# LD_ROOM_CLEANUP_MS=300000
# LD_WS_HEARTBEAT_MS=30000
# LD_WS_HEARTBEAT_TIMEOUT_MS=60000
# LAN 房间 ID 哈希 salt（建议持久化；不设则每次重启随机生成，客户端 opt-out 记录会失效）
# LD_LAN_HASH_SALT=随机 32 hex 字符串

# STUN/TURN（design.md §13.3）
# LD_STUN_PRIMARY=stun:stun.l.google.com:19302
# LD_STUN_BACKUP=stun:stun.qq.com:3478
# LD_TURN_URL=
# LD_TURN_USERNAME=
# LD_TURN_CREDENTIAL=

# 跨网（非局域网）文件发送大小上限（字节，默认 100 MB）
# LD_WAN_MAX_FILE_SIZE=104857600
